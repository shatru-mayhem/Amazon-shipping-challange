# Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Required for admin operations (bypasses RLS). Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret checked against the x-zapier-callback-secret header on
# POST /api/zapier-draft-callback (see that route for the Zap setup).
ZAPIER_CALLBACK_SECRET=

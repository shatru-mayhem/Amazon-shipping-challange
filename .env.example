# ---- Supabase (Settings -> API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Optional; admin operations bypass RLS. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Ingestion (lib/ingestion-db.ts) --------------------------------
# Write-capable Postgres connection string using the app_ingestion role
# (see supabase/schema_hardening.sql §2). Required for tender/email import.
APP_INGESTION_DB_URL=

# ---- Python skills bridge (lib/skills-bridge.ts) --------------------
# URL + shared secret of the deployed service/ container (Railway etc.,
# see service/README.md). Both must be set together.
PYTHON_SKILLS_SERVICE_URL=
PYTHON_SKILLS_SERVICE_TOKEN=

# ---- Zapier draft flow (app/api/zapier-draft-callback) --------------
# Shared secret checked against the x-zapier-callback-secret header.
ZAPIER_CALLBACK_SECRET=
